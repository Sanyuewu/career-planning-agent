# =====================================================================
# 职业规划智能体 - 环境配置示例
# 复制此文件为 .env 并填写真实值：cp .env.example .env
# =====================================================================

# ── 应用环境 ──────────────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── LLM 配置（必填：至少选一个供应商并填入 API Key） ─────────────────
# 供应商选项: deepseek | qwen | groq | ollama
LLM_PROVIDER=deepseek

# DeepSeek（推荐，首选）
# 申请地址: https://platform.deepseek.com/
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=60

# Groq（备选，速度快，免费额度大）
# 申请地址: https://console.groq.com/
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx
# 设置 GROQ_API_KEY 后，启动时会自动切换到 Groq

# Qwen（阿里云百炼，国内访问稳定）
# LLM_PROVIDER=qwen
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── JWT 鉴权（生产环境必须修改！） ───────────────────────────────────
# 生成随机密钥: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=career-planner-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# ── 数据库 ────────────────────────────────────────────────────────────
# 默认使用 SQLite（开发环境无需修改）
DATABASE_URL=sqlite+aiosqlite:///./data/career.db

# ── 文件存储 ──────────────────────────────────────────────────────────
FILE_STORAGE=local           # local | minio
LOCAL_STORAGE_DIR=./data/uploads

# ── 功能开关 ──────────────────────────────────────────────────────────
MOCK_LLM=false               # true = 使用 Mock LLM（无需 API Key，仅供本地测试）
FEATURE_SEMANTIC_MATCH=true
FEATURE_EMOTION_ANALYSIS=true

# ── 性能调优 ──────────────────────────────────────────────────────────
SEMANTIC_MATCH_THRESHOLD=0.85
RESUME_PARSE_TIMEOUT=120
REPORT_GENERATE_TIMEOUT=60
